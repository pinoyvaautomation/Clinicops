      "enum": ["platform_admin", "clinic_staff", "patient"],
      "default": "patient"
    },
    "default_clinic_id": {
      "type": "string"
    },
    "clinic_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "staff_id": {
      "type": "string"
    },
    "staff_role": {
      "type": "string",
      "enum": ["Admin", "Doctor", "Nurse", "FrontDesk"]
    },
    "patient_profile_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "patient_clinic_ids": {
      "type": "array",
      "items": { "type": "string" }
    },
    "avatar": {
      "type": "string",
      "format": "uri"
    },
    "timezone": {
      "type": "string",
      "maxLength": 64
