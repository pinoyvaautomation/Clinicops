{
  "name": "AppointmentType",
  "type": "object",
  "title": "Appointment Type",
  "description": "Clinic-defined appointment service or visit type.",
  "properties": {
    "clinic_id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 1,
      "default": 30
    },
    "price_cents": {
      "type": "integer",
      "minimum": 0
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["clinic_id", "name"]
}
