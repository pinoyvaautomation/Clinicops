# Database
USE_SQLITE=true
#DATABASE_URL=postgres://clinicops:password@localhost:5432/clinicops
POSTGRES_DB=clinicops
POSTGRES_USER=clinicops
POSTGRES_PASSWORD=clinicops
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Security
# Production checklist:
# - set DEBUG=false
# - set DJANGO_SECURE=true
# - set a real SECRET_KEY
# - set real ALLOWED_HOSTS and CSRF_TRUSTED_ORIGINS
# - set unique SECURED_FIELDS_KEY and SECURED_FIELDS_HASH_SALT
SECRET_KEY=change-me
DEBUG=true
DJANGO_SECURE=false
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Encryption (generate a real key with: python manage.py generate_key)
SECURED_FIELDS_KEY=6aR2acXKTqIqMzD3exR104n2beXqe_NUBUBljxb-Dck=
SECURED_FIELDS_HASH_SALT=095789a3

#SECURED_FIELDS_KEY=TtY8MAeXuhdKDd1HfGUwim-vQ8H7fXyRQ9J8pTi_-lg=
#SECURED_FIELDS_HASH_SALT=dev-salt

#KEY: 6aR2acXKTqIqMzD3exR104n2beXqe_NUBUBljxb-Dck=
#HASH_SALT: 095789a3

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_TIMEOUT=10
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=false
DEFAULT_FROM_EMAIL=ClinicOps <noreply@clinicops.local>
PUBLIC_BRAND_NAME=ClinicOps
PUBLIC_BRAND_COLOR=#0f5132
PUBLIC_LOGO_URL=

# Google social sign-in (existing accounts only)
# Callback URL with the default ClinicOps routing:
# https://your-domain.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email (Resend API)
#EMAIL_BACKEND=core.email_backends.ResendEmailBackend
RESEND_API_KEY=
RESEND_SSL_VERIFY=true
#RESEND_CA_BUNDLE=C:\path\to\corp-ca.pem
RESEND_DEBUG=false
RESEND_USER_AGENT=ClinicOps/1.0

# Reminders
REMINDER_WINDOW_MINUTES=1440

# Booking slots
APPOINTMENT_SLOT_MINUTES=30
APPOINTMENT_DAY_START=9
APPOINTMENT_DAY_END=17
APPOINTMENT_DAYS_AHEAD=7
SEND_BOOKING_CONFIRMATION=false

# PayPal Subscriptions
# Production checklist:
# - set PAYPAL_CLIENT_ID, PAYPAL_SECRET, PAYPAL_PRODUCT_ID, PAYPAL_WEBHOOK_ID
# - set PAYPAL_VERIFY_WEBHOOK=true
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_PRODUCT_ID=
PAYPAL_WEBHOOK_ID=
PAYPAL_VERIFY_WEBHOOK=false
PAYPAL_SSL_VERIFY=true
PAYPAL_CA_BUNDLE=
ENFORCE_SUBSCRIPTION=false
